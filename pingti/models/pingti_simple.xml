<?xml version="1.0" ?>
<mujoco model="pingti_simple">
  <!-- 简化的 PingTi 机械臂仿真模型 -->
  
  <option timestep="0.002" />
  
  <default>
    <joint type="hinge" damping="1" />
    <geom material="geom" />
  </default>
  
  <asset>
    <material name="grid" rgba=".9 .9 .9 1" />
    <material name="geom" rgba=".8 .8 .8 1" />
    <material name="joint" rgba=".2 .6 .8 1" />
  </asset>
  
  <worldbody>
    <!-- 地面 -->
    <geom name="ground" type="plane" size="5 5 1" material="grid" />
    <light mode="targetbody" target="base" />
    
    <!-- 基座 -->
    <body name="base" pos="0 0 0">
      <inertial pos="0 0 0" mass="2">
        <inertia diag="0.1 0.1 0.1"/>
      </inertial>
      <geom name="base_geom" type="box" size="0.1 0.1 0.05" material="joint" />
      
      <!-- 关节 1: 肩膀转动 (Shoulder Pan) -->
      <body name="link1" pos="0 0 0.1">
        <inertial pos="0 0 0.08" mass="0.5">
          <inertia diag="0.01 0.01 0.01"/>
        </inertial>
        <joint name="joint1" type="hinge" axis="0 0 1" pos="0 0 0" range="-3.14 3.14" />
        <geom name="link1_geom" type="cylinder" size="0.02 0.08" pos="0 0 0.08" />
        
        <!-- 关节 2: 肩膀抬起 (Shoulder Lift) -->
        <body name="link2" pos="0 0 0.16">
          <inertial pos="0 0 0.08" mass="0.4">
            <inertia diag="0.005 0.005 0.005"/>
          </inertial>
          <joint name="joint2" type="hinge" axis="0 1 0" pos="0 0 0" range="-1.57 1.57" />
          <geom name="link2_geom" type="cylinder" size="0.018 0.08" pos="0 0 0.08" />
          
          <!-- 关节 3: 肘部弯曲 (Elbow Flex) -->
          <body name="link3" pos="0 0 0.16">
            <inertial pos="0 0 0.08" mass="0.3">
              <inertia diag="0.004 0.004 0.004"/>
            </inertial>
            <joint name="joint3" type="hinge" axis="0 1 0" pos="0 0 0" range="-2.09 2.09" />
            <geom name="link3_geom" type="cylinder" size="0.016 0.08" pos="0 0 0.08" />
            
            <!-- 关节 4: 腕部弯曲 (Wrist Flex) -->
            <body name="link4" pos="0 0 0.16">
              <inertial pos="0 0 0.06" mass="0.2">
                <inertia diag="0.002 0.002 0.002"/>
              </inertial>
              <joint name="joint4" type="hinge" axis="0 1 0" pos="0 0 0" range="-1.57 1.57" />
              <geom name="link4_geom" type="cylinder" size="0.014 0.06" pos="0 0 0.06" />
              
              <!-- 关节 5: 腕部旋转 (Wrist Roll) -->
              <body name="link5" pos="0 0 0.12">
                <inertial pos="0 0 0.04" mass="0.15">
                  <inertia diag="0.001 0.001 0.001"/>
                </inertial>
                <joint name="joint5" type="hinge" axis="1 0 0" pos="0 0 0" range="-3.14 3.14" />
                <geom name="link5_geom" type="cylinder" size="0.012 0.04" pos="0 0 0.04" />
                
                <!-- 末端执行器 (End Effector) -->
                <body name="end_effector" pos="0 0 0.08">
                  <inertial pos="0 0 0" mass="0.1">
                    <inertia diag="0.0005 0.0005 0.0005"/>
                  </inertial>
                  <geom name="ee_geom" type="sphere" size="0.015" material="geom" />
                  <site name="ee_site" pos="0 0 0" size="0.01" />
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  
  <!-- 执行器 -->
  <actuator>
    <motor name="motor1" joint="joint1" ctrlrange="-1 1" />
    <motor name="motor2" joint="joint2" ctrlrange="-1 1" />
    <motor name="motor3" joint="joint3" ctrlrange="-1 1" />
    <motor name="motor4" joint="joint4" ctrlrange="-1 1" />
    <motor name="motor5" joint="joint5" ctrlrange="-1 1" />
  </actuator>
</mujoco>
